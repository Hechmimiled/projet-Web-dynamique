<?php
// Mon panier
session_start();
include "connexion.php";

if (!isset($_SESSION["user_id"])) {
    header("Location: login.php");
    exit;
}

$user_id = $_SESSION["user_id"];
$message = "";

// Supprimer un article du panier
if (isset($_POST["btn_supprimer"])) {
    $item_id = (int) $_POST["item_id"];
    $sql_del = "DELETE FROM Panier WHERE ID = $item_id AND Utilisateur_ID = $user_id";
    if (mysqli_query($conn, $sql_del)) {
        $message = "Article retire du panier.";
    }
}

// Recuperer les articles du panier
$sql = "SELECT p.*, s.Nom AS ServiceNom, d.Date_dispo, d.Heure_debut, d.Heure_fin
        FROM Panier p
        JOIN Services s ON s.ID = p.Service_ID
        JOIN Disponibilites d ON d.ID = p.Disponibilite_ID
        WHERE p.Utilisateur_ID = $user_id
        ORDER BY p.Created_at DESC";
$resultat = mysqli_query($conn, $sql);

// Calculer le total
$total = 0;
$items = array();
while ($item = mysqli_fetch_assoc($resultat)) {
    $items[] = $item;
    $total += $item["Prix"];
}
